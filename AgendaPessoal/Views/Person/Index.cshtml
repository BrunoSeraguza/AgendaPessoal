<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/knockout@3.5.1/build/output/knockout-latest.js"></script>

<script src="~/js/site.js"></script>

<div class="container mt-4">

    <h2 class="mb-3">Cadastro de Pessoa</h2>

    <div class="card p-3 mb-4">
        <div class="row g-2">
            <div class="col-md-4">
                <input class="form-control" type="text" placeholder="Nome" data-bind="value: name" />
            </div>

            <div class="col-md-4">
                <input class="form-control" type="email" placeholder="Email" data-bind="value: email" />
            </div>

            <div class="col-md-3">
                <input class="form-control" type="date" min="1900-01-01"
                       max="2099-12-31" data-bind="value: birthDate" />
            </div>

            <div class="col-md-1 d-grid">
                <button class="btn btn-primary"
                        data-bind="click: save, text: isEditing() ? 'Atualizar' : 'Salvar'">
                </button>
            </div>
        </div>
    </div>

    <h3>Lista de Pessoas</h3>

    <table class="table table-striped table-bordered mt-3">
        <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>Email</th>
                <th>Data Nascimento</th>
                <th style="width: 150px;">Ações</th>
            </tr>
        </thead>

        <tbody data-bind="foreach: people">
            <tr>
                <td data-bind="text: name"></td>
                <td data-bind="text: email"></td>
                <td data-bind="text: $parent.formatDate(birthDate)"></td>
                <td>
                    <button class="btn btn-warning btn-sm me-1"
                            data-bind="click: $parent.edit">
                        Editar
                    </button>

                    <button class="btn btn-danger btn-sm"
                            data-bind="click: $parent.delete">
                        Excluir
                    </button>
                </td>
            </tr>
        </tbody>
    </table>

</div>