<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<script src="https://cdn.jsdelivr.net/npm/knockout@3.5.1/build/output/knockout-latest.js"></script>

<div class="container mt-4">

    <h2 class="mb-3">Cadastro de Pessoa</h2>

    <div class="card p-3 mb-4">
        <div class="row g-2">
            <div class="col-md-4">
                <input class="form-control" type="text" placeholder="Nome" data-bind="value: name" />
            </div>

            <div class="col-md-4">
                <input class="form-control" type="email" placeholder="Email" data-bind="value: email" />
            </div>

            <div class="col-md-3">
                <input class="form-control" type="date" data-bind="value: birthDate" />
            </div>

            <div class="col-md-1 d-grid">
                <button class="btn btn-primary" data-bind="click: save">Salvar</button>
            </div>
        </div>
    </div>

    <h3>Lista de Pessoas</h3>

    <table class="table table-striped table-bordered mt-3">
        <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>Email</th>
                <th>Data Nascimento</th>
                <th style="width: 100px;">Ações</th>
            </tr>
        </thead>

        <tbody data-bind="foreach: people">
            <tr>
                <td data-bind="text: name"></td>
                <td data-bind="text: email"></td>
                <td data-bind="text: $parent.formatDate(birthDate)"></td>
                <td>
                    <button class="btn btn-danger btn-sm"
                            data-bind="click: $parent.delete">
                        Excluir
                    </button>
                </td>
            </tr>
        </tbody>
    </table>

</div>

<script>
    function PersonViewModel() {
        var self = this;

        self.name = ko.observable("");
        self.email = ko.observable("");
        self.birthDate = ko.observable("");

        self.people = ko.observableArray([]);

        self.formatDate = function (date) {
            return new Date(date).toLocaleDateString();
        };

        self.save = function () {
            var person = {
                name: self.name(),
                email: self.email(),
                birthDate: self.birthDate()
            };

            fetch('/Person/Create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(person)
            })
            .then(res => {
                if (!res.ok) {
                    return res.text().then(err => { throw err });
                }
            })
            .then(() => {
                self.load();
                self.name("");
                self.email("");
                self.birthDate("");
            })
            .catch(err => alert(err));
        };

        self.load = function () {
            fetch('/Person/GetAll')
                .then(res => res.json())
                .then(data => self.people(data));
        };

        self.delete = function (person) {
            if (!confirm("Deseja excluir essa pessoa?")) return;

            fetch('/Person/Delete?id=' + person.id, {
                method: 'DELETE'
            })
            .then(() => self.load());
        };
    }

    var vm = new PersonViewModel();
    ko.applyBindings(vm);
    vm.load();
</script>